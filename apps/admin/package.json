{
  "name": "gymflex-admin",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "wrangler pages deploy dist --project-name gymflex-admin",
    "cf:whoami": "wrangler whoami",
    "d1:migrate": "wrangler d1 execute <your-d1-name> --remote --file=./migrations/0001_initial_schema.sql && wrangler d1 execute <your-d1-name> --remote --file=./migrations/0004_site_settings.sql",
    "d1:seed": "node ./scripts/generate-seed-from-storefront.mjs && wrangler d1 execute <your-d1-name> --remote --file=./migrations/0002_seed_catalog.sql"
  },
  "dependencies": {
    "@fontsource-variable/figtree": "^5.2.10",
    "@fontsource/poppins": "^5.2.7",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.18.0",
    "zero-template": "file:../.."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12",
    "wrangler": "^4.86.0"
  }
}
