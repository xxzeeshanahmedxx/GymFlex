# Cloudflare account
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# Store resource names
STORE_SLUG=your-store
STORE_NAME="Your Store"
D1_NAME=your_store_d1
KV_NAME=your_store_kv
R2_BUCKET=your-store-r2
STOREFRONT_PROJECT=your-store
ADMIN_PROJECT=your-store-admin

# Cloudflare Pages secrets
ADMIN_PASSWORD=ChangeThisAdminPassword
CLOUDFLARE_ZONE_ID=optional_zone_id_for_custom_domain
CLOUDFLARE_CACHE_PURGE_TOKEN=optional_cache_purge_token
